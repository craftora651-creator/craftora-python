# ==================== DATABASE ====================
DATABASE_URL=postgresql+asyncpg://admin:12345@localhost:5432/CraftoraDesing
DATABASE_ECHO=false
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=40
DATABASE_POOL_RECYCLE=3600
DATABASE_POOL_TIMEOUT=30

# ==================== REDIS ====================
REDIS_URL=redis://localhost:6379/0
REDIS_POOL_SIZE=10
REDIS_DECODE_RESPONSES=true

# ==================== CORS ====================
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:9003", "http://localhost:9004"]

# ==================== API ====================
API_PREFIX=/api
PROJECT_NAME=Craftora
PROJECT_VERSION=1.0.0
PROJECT_DESCRIPTION=E-commerce platform for digital creators

# ==================== GOOGLE OAUTH ====================
GOOGLE_REDIRECT_URI=http://localhost:9004/api/auth/google/callback
VITE_FASTAPI_URL=https://colleague-logic-oregon-appendix.trycloudflare.com
# ==================== APPLE OAUTH ====================
APPLE_REDIRECT_URI=http://localhost:9004/api/auth/apple/callback

# ==================== AWS S3 ====================
AWS_REGION=us-east-1
AWS_S3_BUCKET=craftora-uploads

# ==================== EMAIL ====================
SMTP_TLS=true
SMTP_FROM_EMAIL=noreply@craftora.com
SMTP_FROM_NAME=Craftora Platform

# ==================== RATE LIMITING ====================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_BURST=20

# ==================== MONITORING ====================
PROMETHEUS_ENABLED=true
HEALTH_CHECK_ENABLED=true

# ==================== CACHE ====================
CACHE_ENABLED=true
CACHE_TTL=300
CACHE_MAX_SIZE=1000

# ==================== FILE UPLOAD ====================
MAX_UPLOAD_SIZE=104857600
ALLOWED_FILE_TYPES=["image/jpeg","image/png","image/gif","image/webp","application/pdf","application/zip","video/mp4","video/quicktime","audio/mpeg","audio/wav"]


# ==================== FEATURE FLAGS ====================
FEATURE_GOOGLE_AUTH=true
FEATURE_APPLE_AUTH=true
FEATURE_STRIPE_PAYMENTS=true
FEATURE_EMAIL_VERIFICATION=true
FEATURE_TWO_FACTOR_AUTH=false
FEATURE_REVIEW_SYSTEM=true
FEATURE_WISHLIST=true

# ==================== SECURITY HEADERS ====================
X_FRAME_OPTIONS=DENY
X_CONTENT_TYPE_OPTIONS=nosniff
X_XSS_PROTECTION="1; mode=block"
STRICT_TRANSPORT_SECURITY="max-age=31536000; includeSubDomains"

# ==================== SESSION MANAGEMENT ====================
SESSION_TIMEOUT=3600
SESSION_REFRESH=true
MAX_SESSIONS_PER_USER=5

# ==================== PASSWORD POLICY ====================
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_NUMBERS=true
PASSWORD_REQUIRE_SPECIAL=true

